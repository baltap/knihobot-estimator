# Example Environment Variables for Knihobot Seller Estimator
# Copy this file to .env.local to configure local settings.

# Analytics Configuration (Optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Google Gemini API Configuration (Required for real AI Spine Photo Scanner, optional otherwise)
# Obtain a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=
